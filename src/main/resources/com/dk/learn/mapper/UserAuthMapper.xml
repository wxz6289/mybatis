<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dk.learn.mapper.UserAuthMapper">
    
    <resultMap id="userAuthResultMap" type="com.dk.learn.entity.UserAuth">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="status" column="status"/>
        <result property="lastLoginTime" column="last_login_time"/>
        <result property="createdTime" column="created_at"/>
        <result property="updatedTime" column="updated_at"/>
    </resultMap>
    
    <resultMap id="operationLogResultMap" type="com.dk.learn.entity.OperationLog">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="operation" column="operation"/>
        <result property="method" column="method"/>
        <result property="params" column="params"/>
        <result property="ip" column="ip"/>
        <result property="userAgent" column="user_agent"/>
        <result property="status" column="status"/>
        <result property="errorMsg" column="error_msg"/>
        <result property="operationTime" column="operation_time"/>
    </resultMap>
    
    <!-- 根据用户名查询用户认证信息 -->
    <select id="findByUsername" resultMap="userAuthResultMap">
        SELECT * FROM user_auth WHERE username = #{username}
    </select>
    
    <!-- 根据ID查询用户认证信息 -->
    <select id="findById" resultMap="userAuthResultMap">
        SELECT * FROM user_auth WHERE id = #{id}
    </select>
    
    <!-- 插入用户认证信息 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_auth(username, password, email, phone, status, created_at, updated_at) 
        VALUES(#{username}, #{password}, #{email}, #{phone}, #{status}, #{createdTime}, #{updatedTime})
    </insert>
    
    <!-- 更新用户认证信息 -->
    <update id="update">
        UPDATE user_auth 
        SET password=#{password}, email=#{email}, phone=#{phone}, 
            status=#{status}, last_login_time=#{lastLoginTime}, updated_at=#{updatedTime} 
        WHERE id=#{id}
    </update>
    
    <!-- 更新最后登录时间 -->
    <update id="updateLastLoginTime">
        UPDATE user_auth 
        SET last_login_time=#{lastLoginTime}, updated_at=#{updatedTime} 
        WHERE id=#{id}
    </update>
    
    <!-- 删除用户认证信息 -->
    <delete id="deleteById">
        DELETE FROM user_auth WHERE id=#{id}
    </delete>
    
    <!-- 插入操作日志 -->
    <insert id="insertOperationLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO operation_log(user_id, username, operation, method, params, ip, user_agent, status, error_msg, operation_time) 
        VALUES(#{userId}, #{username}, #{operation}, #{method}, #{params}, #{ip}, #{userAgent}, #{status}, #{errorMsg}, #{operationTime})
    </insert>
    
    <!-- 查询操作日志列表 -->
    <select id="findOperationLogs" resultMap="operationLogResultMap">
        SELECT * FROM operation_log ORDER BY operation_time DESC LIMIT #{offset}, #{size}
    </select>
    
    <!-- 统计操作日志总数 -->
    <select id="countOperationLogs" resultType="long">
        SELECT COUNT(*) FROM operation_log
    </select>
</mapper>